<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.shape.Rectangle?>
<VBox xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.standtrain.controllers.TrainMovement"
      spacing="20" alignment="CENTER">

    <!-- Speed control -->
    <Label text="Управление скоростью" styleClass="title-label"/>

    <!-- Lever container -->
    <StackPane styleClass="lever-box">
        <!-- Slider -->
        <Slider fx:id="speedSlider"
                blockIncrement="1"
                majorTickUnit="10"
                minorTickCount="4"
                showTickMarks="true"
                showTickLabels="true"
                orientation="VERTICAL"
                styleClass="vertical-slider"/>
    </StackPane>

    <Label fx:id="speedLabel" text="Speed: 0"/>

    <!-- Direction control -->
    <Button fx:id="directionButton" text="Изменить направление"/>
</VBox>
