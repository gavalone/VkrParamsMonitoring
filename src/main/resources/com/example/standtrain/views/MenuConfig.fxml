<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500" prefWidth="600" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.standtrain.controllers.MenuConfig">
    <VBox alignment="CENTER" spacing="30" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">

        <!-- Buttons area -->
        <HBox alignment="CENTER" spacing="50">
            <VBox alignment="CENTER" spacing="15">
                <Button onAction="#e16initialize" text="Инициализация E16" />
                <Button onAction="#launchADCThread" text="Запустить сбор E16" />
                <Button onAction="#stopADCThread" text="Остановить сбор E16" />
            </VBox>
            <VBox alignment="CENTER" spacing="15">
                <Button onAction="#LTAInititialize" text="Инициализация LTA" />
                <Button onAction="#launchLTAThread" text="Запустить сбор LTA" />
                <Button onAction="#closeLTAThread" text="Остановить сбор LTA" />
            </VBox>
        </HBox>

        <!-- Log box -->
        <TextArea fx:id="logBox" editable="false" prefHeight="300" styleClass="log-box" wrapText="true" />
    </VBox>

</AnchorPane>
